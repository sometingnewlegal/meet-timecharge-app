# Stripe（テストモードはsk_test_から始まるキー。本番運用時のみsk_live_に切り替える）
STRIPE_SECRET_KEY=

# Google Calendar/Meet 連携
# credentials.json / token.json の中身をそのまま1行のJSON文字列として貼り付ける
# （本番ではファイルではなく環境変数からのみ読み込む）
GOOGLE_CREDENTIALS_JSON=
GOOGLE_TOKEN_JSON=

# データベース（Vercelの Storage タブで Neon/Postgres を接続すると自動的に設定される。手動入力は不要）
# DATABASE_URL=
